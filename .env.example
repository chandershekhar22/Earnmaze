# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/earnmaze

# Admin User Configuration (Auto-created on startup if not exists)
ADMIN_EMAIL=admin@earnmaze.com
ADMIN_PASSWORD=change_this_password_in_production
ADMIN_NAME=Admin User

# Application
NODE_ENV=development
PORT=5173

# UID Hashing Secret
UID_SECRET=your-secret-key-change-in-production

# Email (if using Resend)
RESEND_API_KEY=your-resend-api-key
