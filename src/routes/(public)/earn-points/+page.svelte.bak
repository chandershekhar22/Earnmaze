<script lang="ts">
	import { onMount } from 'svelte';
	import {
		getVisitorId,
		getSessionId,
		getUtmParams,
		trackPageVisit,
		trackCtaClick,
		markVisitStart,
		getTimeToConvert
	} from '$lib/analytics';
	import Turnstile from '$lib/components/Turnstile.svelte';
	import { X, Sparkles, Loader2, ChevronRight, Star, Zap, Shield, Gift, Clock, TrendingUp } from '@lucide/svelte';

	let showEmailModal = $state(false);
	let email = $state('');
	let isSubmitting = $state(false);
	let errorMessage = $state('');
	let turnstileToken = $state<string | null>(null);
	let turnstileRef = $state<any>(null);

	const rewards = [
		{ name: 'PayPal Cash', icon: '💵', popular: true },
		{ name: 'Amazon', icon: '🛒', popular: true },
		{ name: 'Visa Prepaid', icon: '💳', popular: false },
		{ name: 'Google Play', icon: '🎮', popular: false },
	];

	const steps = [
		{ icon: Star, title: 'Sign Up Free', desc: 'Takes 30 seconds' },
		{ icon: Zap, title: 'Take Surveys', desc: 'Quick & easy tasks' },
		{ icon: Gift, title: 'Earn Rewards', desc: 'Cash, cards & more' },
	];

	const stats = [
		{ value: '147K+', label: 'Active Members' },
		{ value: '2M+', label: 'Surveys Completed' },
		{ value: '$500K+', label: 'Rewards Paid Out' },
	];

	onMount(() => {
		markVisitStart();
		trackPageVisit();
	});

	function openEmailModal(e: Event) {
		e.preventDefault();
		const button = e.target as HTMLElement;
		const location = button.closest('section')?.querySelector('h1') ? 'hero' : 'final-cta';
		trackCtaClick(location);
		showEmailModal = true;
		errorMessage = '';
		email = '';
	}

	function closeEmailModal() {
		showEmailModal = false;
		errorMessage = '';
		email = '';
		turnstileToken = null;
	}

	async function handleSubmit(e: Event) {
		e.preventDefault();
		if (!email || !email.includes('@')) {
			errorMessage = 'Please enter a valid email address';
			return;
		}
		if (!turnstileToken) {
			errorMessage = 'Please complete the verification';
			return;
		}

		isSubmitting = true;
		errorMessage = '';

		try {
			const response = await fetch('/api/save-email', {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({
					email,
					visitorId: getVisitorId(),
					sessionId: getSessionId(),
					utmParams: getUtmParams(),
					timeToConvert: getTimeToConvert(),
					turnstileToken
				})
			});

			const data = await response.json();
			if (response.ok && data.success) {
				window.location.href = data.redirectUrl || '/guest/dashboard';
			} else {
				errorMessage = data.error || 'Something went wrong. Please try again.';
				isSubmitting = false;
				turnstileRef?.reset();
				turnstileToken = null;
			}
		} catch {
			errorMessage = 'Network error. Please try again.';
			isSubmitting = false;
			turnstileRef?.reset();
			turnstileToken = null;
		}
	}

	function handleTurnstileVerify(token: string) { turnstileToken = token; errorMessage = ''; }
	function handleTurnstileError() { turnstileToken = null; }
	function handleTurnstileExpire() { turnstileToken = null; }
</script>

<svelte:head>
	<title>Earn Rewards with Paid Surveys | EarnMaze - Get Rewarded for Your Opinion</title>
	<meta name="description" content="Join thousands earning points with paid surveys. Instant rewards, gift cards & PayPal cash. Sign up FREE today! No credit card required." />
	<meta name="keywords" content="paid surveys, earn rewards online, survey points, earn from home, online surveys for rewards, get rewarded for opinions, survey rewards" />
	<meta property="og:title" content="Earn Rewards with Paid Surveys | EarnMaze" />
	<meta property="og:description" content="Get rewarded for sharing your opinions! Join members earning points with surveys. Instant rewards available." />
	<meta property="og:type" content="website" />
	<meta property="og:url" content="https://earnmaze.com/earn-money" />
	<meta name="twitter:card" content="summary_large_image" />
	<meta name="twitter:title" content="Earn Rewards with Paid Surveys | EarnMaze" />
	<meta name="twitter:description" content="Join thousands earning points with paid surveys. Instant rewards & gift cards. 100% Free!" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
	<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
	<link rel="canonical" href="https://earnmaze.com/earn-money" />
</svelte:head>

<!-- Hero — compact, high-impact -->
<section class="relative overflow-hidden bg-gradient-to-br from-violet-600 via-indigo-600 to-violet-700 pt-12 pb-10 sm:pt-16 sm:pb-14" aria-labelledby="hero-heading">
	<div class="absolute inset-0 overflow-hidden" aria-hidden="true">
		<div class="absolute top-0 left-0 w-64 h-64 bg-white/10 rounded-full blur-3xl"></div>
		<div class="absolute bottom-0 right-0 w-64 h-64 bg-yellow-300/15 rounded-full blur-3xl"></div>
	</div>
	<div class="relative max-w-4xl mx-auto px-4 sm:px-6 text-center">
		<div class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-yellow-400 text-gray-900 rounded-full text-xs font-bold mb-5 shadow-lg">
			<span aria-hidden="true">🔥</span> LIMITED: 100 Point Sign-Up Bonus!
		</div>
		<h1 id="hero-heading" class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-white mb-3 sm:mb-4 leading-[1.15]">
			Get Paid for<br />Your Opinion
		</h1>
		<p class="text-sm sm:text-base text-white/85 mb-6 max-w-lg mx-auto leading-relaxed">
			Take quick surveys, earn points, redeem for <strong class="text-yellow-300">PayPal cash</strong> or gift cards. No experience needed.
		</p>
		<button
			onclick={openEmailModal}
			class="group inline-flex items-center justify-center gap-2 px-7 py-3.5 sm:px-9 sm:py-4 bg-yellow-400 text-gray-900 rounded-xl font-bold text-base sm:text-lg hover:bg-yellow-300 active:bg-yellow-500 hover:scale-[1.03] active:scale-[0.97] transition-all shadow-2xl hover:shadow-yellow-400/40 touch-manipulation"
			aria-label="Start earning points now for free"
		>
			START EARNING — IT'S FREE
			<ChevronRight class="w-5 h-5 group-hover:translate-x-0.5 transition-transform" />
		</button>
		<div class="flex flex-wrap justify-center gap-4 sm:gap-6 mt-6 text-white/80 text-xs sm:text-sm">
			<span class="flex items-center gap-1"><span class="text-green-300">✓</span> 100% Free</span>
			<span class="flex items-center gap-1"><span class="text-green-300">✓</span> Instant Points</span>
			<span class="flex items-center gap-1"><span class="text-green-300">✓</span> No Credit Card</span>
		</div>
	</div>
</section>

<!-- Social Proof Bar -->
<div class="bg-neutral-900 py-4">
	<div class="max-w-4xl mx-auto px-4 flex justify-center gap-8 sm:gap-14">
		{#each stats as stat}
			<div class="text-center">
				<div class="text-lg sm:text-xl font-extrabold text-yellow-400">{stat.value}</div>
				<div class="text-[10px] sm:text-xs text-neutral-400 uppercase tracking-wide">{stat.label}</div>
			</div>
		{/each}
	</div>
</div>

<!-- Ad Slot #1 — top leaderboard -->
<div class="bg-neutral-100 py-3 text-center">
	<div class="max-w-[728px] mx-auto min-h-[90px] flex items-center justify-center border border-dashed border-neutral-300 rounded text-neutral-400 text-xs">
		<!-- Ad: 728×90 Leaderboard -->
	</div>
</div>

<!-- How It Works -->
<section class="py-10 sm:py-14 bg-white" aria-labelledby="how-heading">
	<div class="max-w-4xl mx-auto px-4 sm:px-6">
		<h2 id="how-heading" class="text-xl sm:text-2xl md:text-3xl font-extrabold text-neutral-900 text-center mb-8">
			How It Works
		</h2>
		<div class="grid grid-cols-1 sm:grid-cols-3 gap-5 sm:gap-6">
			{#each steps as step, i}
				<div class="relative flex flex-col items-center text-center p-5 rounded-xl bg-neutral-50 border border-neutral-200">
					<div class="w-10 h-10 rounded-full bg-violet-100 text-violet-600 flex items-center justify-center mb-3 font-bold text-sm">{i + 1}</div>
					<svelte:component this={step.icon} class="w-6 h-6 text-violet-500 mb-2" />
					<h3 class="text-sm sm:text-base font-bold text-neutral-900">{step.title}</h3>
					<p class="text-xs text-neutral-500 mt-1">{step.desc}</p>
				</div>
			{/each}
		</div>
	</div>
</section>

<!-- Rewards Showcase -->
<section class="py-10 sm:py-14 bg-neutral-50" aria-labelledby="rewards-heading">
	<div class="max-w-4xl mx-auto px-4 sm:px-6">
		<div class="text-center mb-6">
			<h2 id="rewards-heading" class="text-xl sm:text-2xl md:text-3xl font-extrabold text-neutral-900 mb-1">
				Choose Your <span class="text-violet-600">Reward</span>
			</h2>
			<p class="text-xs sm:text-sm text-neutral-500">Redeem points for cash or gift cards</p>
		</div>
		<div class="grid grid-cols-2 sm:grid-cols-4 gap-3 sm:gap-4 mb-4" role="list">
			{#each rewards as reward}
				<div class="relative group" role="listitem">
					{#if reward.popular}
						<div class="absolute -top-1.5 -right-1.5 bg-gradient-to-r from-orange-400 to-red-500 text-white text-[9px] font-bold px-1.5 py-0.5 rounded-full shadow z-10">HOT</div>
					{/if}
					<div class="p-4 bg-white rounded-xl border border-neutral-200 hover:border-violet-400 hover:shadow-lg transition-all text-center group-hover:-translate-y-0.5">
						<div class="text-2xl sm:text-3xl mb-1" aria-hidden="true">{reward.icon}</div>
						<div class="text-xs sm:text-sm font-bold text-neutral-700">{reward.name}</div>
					</div>
				</div>
			{/each}
		</div>
		<p class="text-center text-xs text-neutral-500 font-medium">+ More reward options available</p>
	</div>
</section>

<!-- Ad Slot #2 — mid-page rectangle -->
<div class="bg-neutral-100 py-3 text-center">
	<div class="max-w-[336px] mx-auto min-h-[280px] flex items-center justify-center border border-dashed border-neutral-300 rounded text-neutral-400 text-xs">
		<!-- Ad: 336×280 Large Rectangle -->
	</div>
</div>

<!-- Why EarnMaze -->
<section class="py-10 sm:py-14 bg-white" aria-labelledby="why-heading">
	<div class="max-w-4xl mx-auto px-4 sm:px-6">
		<h2 id="why-heading" class="text-xl sm:text-2xl md:text-3xl font-extrabold text-neutral-900 text-center mb-8">
			Why Members Love <span class="text-violet-600">EarnMaze</span>
		</h2>
		<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
			<div class="flex gap-3 p-4 rounded-xl bg-violet-50 border border-violet-100">
				<Clock class="w-5 h-5 text-violet-500 shrink-0 mt-0.5" />
				<div>
					<h3 class="text-sm font-bold text-neutral-900">Quick Surveys</h3>
					<p class="text-xs text-neutral-600 mt-0.5">Most take under 5 minutes to complete</p>
				</div>
			</div>
			<div class="flex gap-3 p-4 rounded-xl bg-green-50 border border-green-100">
				<TrendingUp class="w-5 h-5 text-green-500 shrink-0 mt-0.5" />
				<div>
					<h3 class="text-sm font-bold text-neutral-900">Instant Points</h3>
					<p class="text-xs text-neutral-600 mt-0.5">Earn points right after completing a survey</p>
				</div>
			</div>
			<div class="flex gap-3 p-4 rounded-xl bg-yellow-50 border border-yellow-100">
				<Gift class="w-5 h-5 text-yellow-500 shrink-0 mt-0.5" />
				<div>
					<h3 class="text-sm font-bold text-neutral-900">Real Rewards</h3>
					<p class="text-xs text-neutral-600 mt-0.5">PayPal cash, Amazon, and major gift cards</p>
				</div>
			</div>
			<div class="flex gap-3 p-4 rounded-xl bg-blue-50 border border-blue-100">
				<Shield class="w-5 h-5 text-blue-500 shrink-0 mt-0.5" />
				<div>
					<h3 class="text-sm font-bold text-neutral-900">Privacy First</h3>
					<p class="text-xs text-neutral-600 mt-0.5">Your data stays secure and never sold</p>
				</div>
			</div>
		</div>
	</div>
</section>

<!-- Final CTA -->
<section class="relative py-10 sm:py-14 overflow-hidden" aria-labelledby="cta-heading">
	<div class="absolute inset-0 bg-gradient-to-br from-violet-700 via-violet-600 to-amber-500" aria-hidden="true"></div>
	<div class="relative max-w-3xl mx-auto px-4 sm:px-6 text-center">
		<div class="inline-flex items-center gap-1.5 bg-yellow-400 text-gray-900 px-3 py-1.5 rounded-full font-bold mb-5 text-xs shadow-lg">
			<span aria-hidden="true">⚡</span> Limited: 50 Bonus Points NOW!
		</div>
		<h2 id="cta-heading" class="text-2xl sm:text-3xl md:text-4xl font-black text-white mb-3 leading-tight">
			Ready to Start Earning?
		</h2>
		<p class="text-sm sm:text-base text-yellow-100 mb-6 max-w-lg mx-auto">
			Join <strong class="text-yellow-300">147,892 people</strong> who earn points daily
		</p>
		<button
			onclick={openEmailModal}
			class="inline-flex items-center gap-2 bg-yellow-400 hover:bg-yellow-300 text-gray-900 px-7 py-3.5 sm:px-9 sm:py-4 rounded-xl text-base sm:text-lg font-black shadow-2xl hover:shadow-yellow-400/40 hover:scale-[1.03] active:scale-[0.97] transition-all touch-manipulation"
			aria-label="Sign up now to start earning points for free"
		>
			<span aria-hidden="true">🚀</span> Start Earning Now — FREE!
		</button>
		<div class="mt-6 flex flex-wrap justify-center gap-4 text-white/80 text-xs" role="list">
			<span class="flex items-center gap-1" role="listitem">🔒 SSL Secured</span>
			<span class="flex items-center gap-1" role="listitem">🔐 Privacy Protected</span>
			<span class="flex items-center gap-1" role="listitem">💯 100% Free</span>
		</div>
		<p class="mt-4 text-[10px] sm:text-xs text-yellow-100/70">No credit card &bull; Cancel anytime &bull; Data protected</p>
	</div>
</section>

<!-- Ad Slot #3 — bottom leaderboard -->
<div class="bg-neutral-100 py-3 text-center">
	<div class="max-w-[728px] mx-auto min-h-[90px] flex items-center justify-center border border-dashed border-neutral-300 rounded text-neutral-400 text-xs">
		<!-- Ad: 728×90 Leaderboard -->
	</div>
</div>

<!-- Email Modal -->
{#if showEmailModal}
	<!-- svelte-ignore a11y_click_events_have_key_events -->
	<!-- svelte-ignore a11y_no_static_element_interactions -->
	<div
		class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/50 backdrop-blur-sm"
		onclick={closeEmailModal}
		onkeydown={(e) => e.key === 'Escape' && closeEmailModal()}
		role="dialog"
		aria-modal="true"
		aria-labelledby="modal-title"
		tabindex="-1"
	>
		<!-- svelte-ignore a11y_click_events_have_key_events -->
		<!-- svelte-ignore a11y_no_static_element_interactions -->
		<!-- svelte-ignore a11y_no_noninteractive_element_interactions -->
		<div
			class="bg-white rounded-2xl shadow-2xl max-w-md w-full p-6 sm:p-8 relative"
			onclick={(e) => e.stopPropagation()}
			role="document"
		>
			<button onclick={closeEmailModal} class="absolute top-3 right-3 text-neutral-400 hover:text-neutral-600 transition-colors" aria-label="Close modal">
				<X class="w-5 h-5" />
			</button>
			<div class="text-center mb-5">
				<div class="w-12 h-12 bg-violet-100 rounded-xl flex items-center justify-center mx-auto mb-2.5">
					<Sparkles class="w-6 h-6 text-violet-600" />
				</div>
				<h3 id="modal-title" class="text-xl sm:text-2xl font-bold text-neutral-900 mb-1">Get Started Now!</h3>
				<p class="text-sm text-neutral-600">Enter your email to claim your bonus</p>
			</div>
			<form onsubmit={handleSubmit} class="space-y-3">
				<div>
					<label for="email-input" class="sr-only">Email address</label>
					<input
						id="email-input"
						type="email"
						bind:value={email}
						placeholder="you@email.com"
						required
						disabled={isSubmitting}
						class="w-full px-4 py-3 border-2 border-neutral-300 rounded-lg focus:border-violet-500 focus:ring-2 focus:ring-violet-200 outline-none transition-all text-base disabled:bg-neutral-100 disabled:cursor-not-allowed"
					/>
				</div>
				{#if errorMessage}
					<div class="bg-red-50 border border-red-200 text-red-600 px-3 py-2 rounded-lg text-sm" role="alert">{errorMessage}</div>
				{/if}
				<div class="flex justify-center py-1">
					<Turnstile bind:this={turnstileRef} onVerify={handleTurnstileVerify} onError={handleTurnstileError} onExpire={handleTurnstileExpire} theme="auto" size="normal" />
				</div>
				<button
					type="submit"
					disabled={isSubmitting || !turnstileToken}
					class="w-full bg-gradient-to-r from-violet-600 to-indigo-600 hover:from-violet-700 hover:to-indigo-700 text-white font-bold py-3 px-6 rounded-lg transition-all shadow-lg hover:shadow-xl disabled:opacity-50 disabled:cursor-not-allowed flex items-center justify-center gap-2"
				>
					{#if isSubmitting}
						<Loader2 class="animate-spin h-5 w-5" />
						<span>Processing...</span>
					{:else}
						<span>Continue →</span>
					{/if}
				</button>
			</form>
			<p class="mt-3 text-[10px] text-center text-neutral-400">
				By continuing, you agree to our <a href="/terms-of-service" class="underline">Terms</a> & <a href="/privacy-policy" class="underline">Privacy Policy</a>
			</p>
		</div>
	</div>
{/if}